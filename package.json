{
  "name": "@foxsecura/anti-nuke",
  "version": "0.1.0",
  "description": "A modular TypeScript anti-nuke toolkit for Discord bots.",
  "license": "MIT",
  "author": "FoxSecura",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./discordjs": {
      "types": "./dist/adapters/discordjs/index.d.ts",
      "import": "./dist/adapters/discordjs/index.js"
    },
    "./modules": {
      "types": "./dist/modules/index.d.ts",
      "import": "./dist/modules/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "keywords": [
    "discord",
    "discord.js",
    "anti-nuke",
    "security",
    "audit-log",
    "typescript"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "discord.js": ">=14.15.0 <15"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^24.0.14",
    "discord.js": "^14.26.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FoxSecura/Anti-Nuke.git"
  },
  "bugs": {
    "url": "https://github.com/FoxSecura/Anti-Nuke/issues"
  },
  "homepage": "https://github.com/FoxSecura/Anti-Nuke#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "overrides": {
    "undici": "6.27.0"
  }
}
